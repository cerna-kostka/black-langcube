# ── LLM Provider Configuration ────────────────────────────────────────────────
# Global default provider used by every step that does not have its own override.
# Supported values: openai, gemini, mistral
PROVIDER=openai

# ── Per-Step Provider Overrides (optional) ────────────────────────────────────
# If not set, each step falls back to PROVIDER.
# ANALYST_PROVIDER=gemini
# OUTLINE_PROVIDER=openai
# TEXT_PROVIDER=gemini
# CHECK_TITLE_PROVIDER=openai
# TITLE_ABSTRACT_PROVIDER=openai
# LOW_PROVIDER=openai
# HIGH_PROVIDER=openai

# ── OpenAI Model Names (optional, defaults shown) ─────────────────────────────
# OPENAI_MODEL_LOW=gpt-4o-mini
# OPENAI_MODEL_HIGH=gpt-4.1
# OPENAI_MODEL_ANALYST=gpt-4.1
# OPENAI_MODEL_OUTLINE=gpt-4.1
# OPENAI_MODEL_TEXT=gpt-4.1
# OPENAI_MODEL_CHECK_TITLE=gpt-4.1
# OPENAI_MODEL_TITLE_ABSTRACT=gpt-4.1

# ── Gemini Model Names (optional, defaults shown) ─────────────────────────────
# GEMINI_MODEL_LOW=gemini-2.5-flash
# GEMINI_MODEL_HIGH=gemini-2.5-pro
# GEMINI_MODEL_ANALYST=gemini-2.5-pro
# GEMINI_MODEL_OUTLINE=gemini-2.5-pro
# GEMINI_MODEL_TEXT=gemini-2.5-pro
# GEMINI_MODEL_CHECK_TITLE=gemini-2.5-flash
# GEMINI_MODEL_TITLE_ABSTRACT=gemini-2.5-flash

# ── Mistral Model Names (optional, defaults shown) ────────────────────────────
# MISTRAL_MODEL_LOW=mistral-small-latest
# MISTRAL_MODEL_HIGH=mistral-large-latest
# MISTRAL_MODEL_ANALYST=mistral-large-latest
# MISTRAL_MODEL_OUTLINE=mistral-large-latest
# MISTRAL_MODEL_TEXT=mistral-large-latest
# MISTRAL_MODEL_CHECK_TITLE=mistral-small-latest
# MISTRAL_MODEL_TITLE_ABSTRACT=mistral-small-latest

# ── API Keys ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY=your-openai-key-here
# GEMINI_API_KEY=your-gemini-key-here
# MISTRAL_API_KEY=your-mistral-key-here

# ── Storage Configuration ─────────────────────────────────────────────────────
# Controls where workflow results are stored.
# Supported values: file (default), database, dual
# STORAGE_MODE=file

# Database connection URL (required when STORAGE_MODE=database or dual).
# Async dialects are applied automatically.
# DATABASE_URL=sqlite:///./black_langcube.db
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── LangChain / LangSmith (optional) ─────────────────────────────────────────
# LANGCHAIN_API_KEY=your-langchain-api-key-here
# LANGCHAIN_TRACING_V2=true
